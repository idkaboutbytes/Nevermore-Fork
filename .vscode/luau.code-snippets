{
	"Loader bootstrap": {
		"scope": "luau,lua",
		"prefix": "loader",
		"description": "Relative-require loader bootstrap — add a `../` per level of nesting (Nevermore-Fork CLAUDE.md)",
		"body": [
			"const require = require(\"${1:..}/Loader\").load()",
			"",
			"$0"
		]
	},

	"Util package": {
		"scope": "luau,lua",
		"prefix": "util",
		"description": "Stateless util module in the fork style (const, @util, camelCase, @checked)",
		"body": [
			"--!strict",
			"--[=[",
			"\t@util ${1}Util",
			"]=]",
			"",
			"const require = require(\"${2:..}/Loader\").load()",
			"",
			"const ${1}Util = {}",
			"",
			"--[=[",
			"\t${3:Does something}",
			"",
			"\t@within ${1}Util",
			"]=]",
			"@checked",
			"function ${1}Util.${4:someMethod}()",
			"\t$0",
			"end",
			"",
			"return ${1}Util",
			""
		]
	},

	"Documentation Block": {
		"scope": "luau,lua",
		"prefix": "doc",
		"description": "Luau documentation block",
		"body": [
			"--[=[",
			"\t${1}",
			"",
			"\t@within ${2}",
			"\t@param ${3} ${4}",
			"\t@returns ${5}",
			"]=]"
		]
	},

	"Service": {
		"scope": "luau,lua",
		"prefix": "service",
		"description": "ServiceBag service in the fork style — Init/Start, exported type, and a Maid",
		"body": [
			"--!strict",
			"--[=[",
			"\t@class ${1:Some}Service",
			"]=]",
			"",
			"const require = require(\"${2:..}/Loader\").load()",
			"",
			"local Maid = require(\"Maid\")",
			"local ServiceBag = require(\"ServiceBag\")",
			"",
			"local ${1:Some}Service = {}",
			"${1:Some}Service.ServiceName = \"${1:Some}Service\"",
			"${3:${4|-- ,|}ServiceName is server-only when uncommented}",
			"",
			"export type ${1:Some}Service = typeof(setmetatable(",
			"\t{} :: {",
			"\t\t_serviceBag: ServiceBag.ServiceBag,",
			"\t\t_maid: Maid.Maid,",
			"\t},",
			"\t{} :: typeof({ __index = ${1:Some}Service })",
			"))",
			"",
			"function ${1:Some}Service.Init(self: ${1:Some}Service, serviceBag: ServiceBag.ServiceBag)",
			"\tassert(not (self :: any)._serviceBag, \"Already initialized\")",
			"\tself._serviceBag = assert(serviceBag, \"No serviceBag\")",
			"\tself._maid = Maid.new()",
			"",
			"\t$0",
			"end",
			"",
			"function ${1:Some}Service.Start(self: ${1:Some}Service) end",
			"",
			"function ${1:Some}Service.Destroy(self: ${1:Some}Service)",
			"\tself._maid:Destroy()",
			"end",
			"",
			"return ${1:Some}Service",
			""
		]
	},

	"Class package": {
		"scope": "luau,lua",
		"prefix": "class",
		"description": "OOP class in the fork style (const, @class, ClassType, .new top / .Destroy bottom, dot-with-typed-self)",
		"body": [
			"--!strict",
			"--[=[",
			"\t@class ${1:SomeClass}",
			"]=]",
			"",
			"const require = require(\"${2:..}/Loader\").load()",
			"",
			"--> Dependencies",
			"const Maid = require(\"Maid\")",
			"",
			"const $1 = {}",
			"$1.ClassName = \"$1\"",
			"$1.__index = $1",
			"",
			"export type ClassType = typeof(setmetatable(",
			"\t{} :: {",
			"\t\t_maid: Maid.Maid,",
			"\t},",
			"\t$1",
			"))",
			"",
			"function $1.new(): ClassType",
			"\tlocal self = setmetatable({}, $1)",
			"\tself._maid = Maid.new()",
			"",
			"\t$0",
			"",
			"\treturn self",
			"end",
			"",
			"function $1.Destroy(self: ClassType)",
			"\tself._maid:DoCleaning()",
			"",
			"\ttable.clear(self)",
			"\tsetmetatable(self, nil)",
			"end",
			"",
			"return $1",
			""
		]
	}
}
